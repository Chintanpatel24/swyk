#!/usr/bin/env bash
set -euo pipefail
S="${BASH_SOURCE[0]}"
while [ -L "$S" ]; do D="$(cd -P "$(dirname "$S")" && pwd)"; S="$(readlink "$S")"; [[ "$S" != /* ]] && S="$D/$S"; done
SWYK_ROOT="$(cd -P "$(dirname "$S")/.." && pwd)"
export SWYK_ROOT SWYK_WORKSPACE="$(pwd)"
PY=""; command -v python3 &>/dev/null && PY=python3 || PY=python
exec "$PY" -u "$SWYK_ROOT/core/main.py" "$@"
